# Twilio credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15555551234

# Public base URL for booking link in auto-SMS (e.g. https://yourapp.com)
BASE_URL=https://your-domain.com

# Optional separate webhook signature secret. If unset, TWILIO_AUTH_TOKEN is used.
TWILIO_WEBHOOK_SECRET=your_twilio_auth_token
